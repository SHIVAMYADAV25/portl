PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_PATH=./portl.db

# Optional — set DB_DRIVER=postgres and DATABASE_URL to use Postgres instead of the default
# zero-setup SQLite file. See README.md "Switching to Postgres".
DB_DRIVER=sqlite
DATABASE_URL=

# Optional — get test keys from https://dashboard.razorpay.com/app/keys
# Without these, payment endpoints return 503 and the app should use POST /bills/:id/pay/mock instead.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional — real SMS OTP via Twilio Verify (https://console.twilio.com/ -> Verify -> Services).
# Without these, /auth/verify-otp accepts the fixed demo code 1234 instead of a real SMS code.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Optional — file storage driver: "local" (default, zero-setup, writes to ./uploads),
# "s3", or "cloudinary". See README.md "File storage" for details.
STORAGE_DRIVER=local

# Required if STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=
# Optional — falls back to the default AWS credential chain (instance role, shared config, etc.)
# if left blank.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional — set this if the bucket is fronted by a CDN/custom domain instead of the raw S3 URL.
S3_PUBLIC_BASE_URL=

# Required if STORAGE_DRIVER=cloudinary (from https://console.cloudinary.com/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — real invite emails via SMTP (Gmail, SendGrid, Mailtrap, SES SMTP, etc). Without
# these, invites are logged to the server console and the activation link is also returned
# directly in the admin API response so the flow is still fully testable end-to-end.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@portl.app

# Deep link base used to build activation links, e.g. portl://activate/<token>. Change this to a
# hosted https:// URL later if you add a universal-link fallback page for email clients that
# don't hand off to the app directly.
APP_DEEP_LINK_BASE=portl://activate