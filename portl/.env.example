# Copy this to .env and adjust for your setup.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time by Expo — see
# https://docs.expo.dev/guides/environment-variables/

# Physical device: use your computer's LAN IP, e.g. http://192.168.1.42:4000
# iOS simulator: http://localhost:4000 usually works
# Android emulator: http://10.0.2.2:4000 (localhost on the host machine, from the emulator's perspective)
EXPO_PUBLIC_API_URL=http://localhost:4000
